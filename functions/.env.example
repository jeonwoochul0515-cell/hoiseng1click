# ─── CODEF (금융·공공기관 수집, 차량등록원부 등) ───
CODEF_API_HOST=https://api.codef.io
CODEF_CLIENT_ID=YOUR_CLIENT_ID
CODEF_CLIENT_SECRET=YOUR_CLIENT_SECRET
CODEF_PUBLIC_KEY=YOUR_PUBLIC_KEY_BASE64

# ─── Anthropic Claude (AI 진술서/서류 검증) ───
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY

# ─── Naver CLOVA OCR (서류 인식) ───
CLOVA_OCR_URL=https://YOUR-APIGW.apigw.ntruss.com/custom/v1/...
CLOVA_OCR_SECRET=YOUR_SECRET

# ─── [Phase B] data.go.kr 공시가격 API ───
# 일반인증키 (Decoding 키) — 발급처: https://www.data.go.kr
# 사용처: 공동주택(APT)/개별단독주택(HOUSE)/개별공시지가(LAND) 3종 NSDI 공시가격 API
PUBLIC_DATA_API_KEY=YOUR_KEY_HERE

# ─── [Phase B] 브이월드 지오코딩 (주소→PNU 변환, 선택) ───
# 발급처: https://www.vworld.kr/dev/v4dv_search.do
# 없으면 도로명주소 API(JUSO_API_KEY) 로 fallback — 없으면 PNU 변환 불가
VWORLD_API_KEY=YOUR_KEY_HERE

# ─── [Phase B] 행안부 도로명주소 API (선택, 브이월드 fallback) ───
# 발급처: https://business.juso.go.kr/addrlink/main.do
JUSO_API_KEY=YOUR_KEY_HERE
