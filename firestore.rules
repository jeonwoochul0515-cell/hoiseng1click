rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /offices/{officeId} {
      // 본인 uid와 officeId가 같으면 읽기/쓰기 허용
      allow create: if request.auth != null && request.auth.uid == officeId;
      allow read: if request.auth != null && (
        request.auth.uid == officeId ||
        (resource != null && request.auth.uid in resource.data.members)
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid == officeId ||
        request.auth.uid in resource.data.members
      );

      match /clients/{clientId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == officeId ||
          get(/databases/$(database)/documents/offices/$(officeId)).data.members.hasAny([request.auth.uid])
        );
      }
    }

    // 의뢰인 접수 링크 토큰
    match /intakeTokens/{tokenId} {
      // PIN은 SHA-256 해시(pinHash)로만 저장되므로 읽기 허용해도 평문 PIN이 노출되지 않음.
      // 추후 Cloud Functions로 검증 로직을 이동하면 allow read: if false로 변경할 것.
      allow read: if true;
      // 사무소 소유자만 토큰 생성
      allow create: if request.auth != null && request.auth.uid == request.resource.data.officeId;
      // 사무소 소유자 또는 트랜잭션에 의한 used 플래그 업데이트 허용
      allow update: if (request.auth != null && request.auth.uid == resource.data.officeId)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used'])
            && request.resource.data.used == true);
      allow delete: if request.auth != null && request.auth.uid == resource.data.officeId;
    }

    // 의뢰인 접수 제출 데이터
    match /intakeSubmissions/{submissionId} {
      allow create: if request.resource.data.keys().hasAll(['tokenId', 'officeId', 'name', 'phone', 'submittedAt']);
      allow read: if request.auth != null && request.auth.uid == resource.data.officeId;
      allow update: if request.auth != null && request.auth.uid == resource.data.officeId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['convertedAt', 'convertedClientId']);
    }
  }
}
