rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOfficeMember(officeId) {
      return isSignedIn() && (
        request.auth.uid == officeId ||
        request.auth.uid in get(/databases/$(database)/documents/offices/$(officeId)).data.members
      );
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /offices/{officeId} {
      allow create: if isSignedIn() && request.auth.uid == officeId;
      allow read: if isSignedIn() && (
        request.auth.uid == officeId ||
        (resource != null && request.auth.uid in resource.data.members)
      );
      allow update, delete: if isSignedIn() && (
        request.auth.uid == officeId ||
        request.auth.uid in resource.data.members
      );

      match /clients/{clientId} {
        allow read: if isOfficeMember(officeId);
        allow create: if isOfficeMember(officeId)
          && (!request.resource.data.keys().hasAny(['ssnEncrypted'])
              || (request.resource.data.ssnEncrypted is string
                  && request.resource.data.ssnEncrypted.size() > 0));
        allow update: if isOfficeMember(officeId)
          && (!request.resource.data.keys().hasAny(['ssnEncrypted'])
              || (request.resource.data.ssnEncrypted is string
                  && request.resource.data.ssnEncrypted.size() > 0));
        allow delete: if isOfficeMember(officeId);
      }

      // 수집 서류 서브컬렉션
      match /clients/{clientId}/documents/{docId} {
        allow read, write: if isOfficeMember(officeId);
      }
    }

    // ── Individual (B2C) 개인 셀프신청 ──
    match /individuals/{uid} {
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow read, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;

      match /cases/{caseId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      match /cases/{caseId}/documents/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }
    }

    match /retainerRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /intakeTokens/{tokenId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && isOfficeMember(request.resource.data.officeId);
      allow update: if (isSignedIn() && isOfficeMember(resource.data.officeId))
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used'])
            && request.resource.data.used == true);
      allow delete: if isSignedIn() && isOfficeMember(resource.data.officeId);
    }

    match /intakeSubmissions/{submissionId} {
      allow create: if request.resource.data.keys().hasAll(['tokenId', 'officeId', 'name', 'phone', 'submittedAt'])
        && exists(/databases/$(database)/documents/intakeTokens/$(request.resource.data.tokenId));
      allow read: if isSignedIn() && isOfficeMember(resource.data.officeId);
      allow update: if isSignedIn() && isOfficeMember(resource.data.officeId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['convertedAt', 'convertedClientId', 'uploadedDocs']);
    }
  }
}
